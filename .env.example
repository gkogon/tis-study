# Atlanta TIS — environment variables
#
# Required for the core app:
DATABASE_URL=postgresql://user:pass@host:5432/db

# Production app origin (used for outbound email links + Stripe return
# URLs). Set to your real domain in production.
PUBLIC_APP_ORIGIN=https://simpleimpactstudies.com

# Comma-separated list of origins allowed for cross-origin requests.
# In production this should be your domain (https://simpleimpactstudies.com).
# Localhost is always allowed in NODE_ENV != production.
ALLOWED_ORIGINS=https://simpleimpactstudies.com

# Where the TIS engine fetches intersection inventory and live GDOT
# data. Points at the analyzer service.
ANALYZER_API_URL=http://localhost:8081

# Local-dev sign-in bypass. Skips email/password auth and grants a
# session to any email submitted to /tis-api/dev-login. NEVER set
# this in production.
DEV_AUTH_ENABLED=true

# Comma-separated emails granted admin access to /admin and friends.
ADMIN_EMAILS=

# Stripe (test mode until banking is added in the Stripe dashboard).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=

# GDOT 511 NaviGAtor v2 developer key. When set, the analyzer pulls
# live incident / DMS / camera feeds via the v2 API instead of the
# keyless rate-limited scrape.
GDOT_511_API_KEY=

# Resend transactional email. Drives password-reset + firm invites.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Replit Object Storage (optional — for firm logo upload on Replit
# deployments). When unset, logos fall back to a data-URL stored
# directly on the firm row.
REPLIT_OBJECT_STORAGE_BUCKET=
