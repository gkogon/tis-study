auto-install-peers=false
strict-peer-dependencies=false
# pnpm 11 errors on a fresh install if any package has a postinstall
# script not listed in onlyBuiltDependencies. We list esbuild + friends
# in pnpm-workspace.yaml; this flag downgrades the strict-mode failure
# to a warning so the install completes on hosts (Railway, CI) that
# don't have a pre-populated node_modules cache.
strict-dep-builds=false
