auto-install-peers=false
strict-peer-dependencies=false
# pnpm 11 refuses (not warns) to run install scripts that aren't
# explicitly approved. Even when the package IS listed in
# `onlyBuiltDependencies` in pnpm-workspace.yaml, fresh installs on
# Railway/CI hit ERR_PNPM_IGNORED_BUILDS for esbuild's native-binary
# postinstall. Setting both flags here bypasses the strict failure
# for non-interactive installs.
strict-dep-builds=false
ignore-scripts=false
node-linker=isolated
