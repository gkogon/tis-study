# Atlanta TIS — environment variables
#
# Required for core app:
DATABASE_URL=postgresql://user:pass@host:5432/db
REPL_ID=                       # Replit Auth client ID (required for OIDC)
ISSUER_URL=https://replit.com/oidc

# Stripe — required only once you're ready to take payments. Without
# these the billing endpoints return 503 but the rest of the app works.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Price IDs (create in Stripe dashboard → Products → add price → copy ID)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...

# Public origin used by Stripe Checkout for success/cancel return URLs.
# Set to your real domain in production. Falls back to REPLIT_DEV_DOMAIN
# or http://localhost:5173 if unset.
PUBLIC_APP_ORIGIN=https://your-domain.example

# GDOT 511 NaviGAtor v2 developer key. When set, the analyzer pulls
# live incident / DMS / camera feeds via the v2 API instead of the
# keyless rate-limited scrape.
GDOT_511_API_KEY=

# Resend transactional email. When set, firm invite emails are
# delivered to the recipient. When unset, the invite link is still
# generated and shown in firm settings — the admin shares it manually.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Replit Object Storage (for white-labeled-PDF firm logo upload).
# Bucket name on Replit. When unset, logo upload falls back to a
# paste-a-URL field.
REPLIT_OBJECT_STORAGE_BUCKET=
